[Unit]
Description=Hexo Server for JBlog
After=network.target

[Service]
Type=simple
User=user
Group=user
WorkingDirectory=/path/to/JBlog
Environment=NODE_ENV=production
ExecStartPre=/path/to/node /path/to/hexo clean
ExecStart=/path/to/node /path/to/hexo server --host 0.0.0.0 --port 4000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
